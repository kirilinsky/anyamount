{
    "name": "anyamount",
    "version": "0.1.0",
    "description": "Tiny smart number formatter — one function, three modes (smart, currency, unit), any Intl locale.",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "packageManager": "pnpm@10.32.1",
    "engines": {
        "node": ">=18"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown && node scripts/cjs-types.mjs && node scripts/check-size.mjs",
        "lint": "oxlint src",
        "publint": "publint",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "release": "npm version patch && git push --follow-tags"
    },
    "keywords": [
        "number",
        "number-format",
        "format",
        "compact",
        "currency",
        "units",
        "unit-format",
        "filesize",
        "bytes",
        "human-readable",
        "humanize",
        "intl",
        "i18n",
        "localization",
        "formatter",
        "lightweight",
        "zero-dependency",
        "typescript",
        "esm",
        "ssr",
        "anywhen"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^22.19.15",
        "@vitest/coverage-v8": "^3.2.4",
        "oxlint": "^1.71.0",
        "publint": "^0.3.21",
        "tsdown": "^0.22.3",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kirilinsky/anyamount.git"
    },
    "author": "Kirilinsky (https://github.com/kirilinsky)",
    "bugs": {
        "url": "https://github.com/kirilinsky/anyamount/issues"
    },
    "homepage": "https://github.com/kirilinsky/anyamount#readme"
}
